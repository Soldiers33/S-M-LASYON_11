{
	"servers": {
		"io.github.netdata/mcp-server": {
			"type": "http",
			"url": "https://app.netdata.cloud/api/v1/mcp",
			"headers": {
				"Authorization": "Bearer ${input:NETDATA_CLOUD_API_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "2.9.0"
		},
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp@0.0.1a4"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"io.github.upstash/context7": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@upstash/context7-mcp@1.0.31"
			],
			"env": {
				"CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.31"
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:0.31.0"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.31.0"
		},
		"oraios/serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"serena@latest",
				"--context",
				"ide-assistant"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"coplaydev/unity-mcp": {
			"type": "stdio",
			"command": "other",
			"args": [
				"--directory",
				"${input:unity_mcp_server_src}",
				"run",
				"server.py"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"firecrawl/firecrawl-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"firecrawl-mcp@latest"
			],
			"env": {
				"FIRECRAWL_API_KEY": "${input:api_key}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"makenotion/notion-mcp-server": {
			"type": "http",
			"url": "https://mcp.notion.com/sse",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"microsoft/azure-devops-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@azure-devops/mcp@latest",
				"${input:ado_org}",
				"-d",
				"${input:ado_domain}"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"io.github.tavily-ai/tavily-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"tavily-mcp@0.2.15"
			],
			"env": {
				"TAVILY_API_KEY": "${input:TAVILY_API_KEY}",
				"DEFAULT_PARAMETERS": "${input:DEFAULT_PARAMETERS}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.2.15"
		},
		"io.github.hashicorp/terraform-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"run",
				"--rm",
				"-i",
				"-e",
				"${input:e}",
				"TFE_ADDRESS",
				"-e",
				"${input:e}",
				"TFE_TOKEN",
				"-e",
				"${input:e}",
				"ENABLE_TF_OPERATIONS",
				"hashicorp/terraform-mcp-server:0.4.0",
				"-e",
				"TFE_ADDRESS",
				"-e",
				"TFE_TOKEN",
				"-e",
				"ENABLE_TF_OPERATIONS",
				"docker.io/hashicorp/terraform-mcp-server:0.4.0"
			],
			"env": {
				"TFE_ADDRESS": "${input:TFE_ADDRESS}",
				"TFE_TOKEN": "${input:TFE_TOKEN}",
				"ENABLE_TF_OPERATIONS": "${input:ENABLE_TF_OPERATIONS}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.4.0"
		},
		"io.github.mongodb-js/mongodb-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"mongodb-mcp-server@1.8.0",
				"--allowRequestOverrides",
				"${input:allowRequestOverrides}",
				"--apiClientId",
				"${input:apiClientId}",
				"--apiClientSecret",
				"${input:apiClientSecret}",
				"--assistantBaseUrl",
				"${input:assistantBaseUrl}",
				"--atlasTemporaryDatabaseUserLifetimeMs",
				"${input:atlasTemporaryDatabaseUserLifetimeMs}",
				"--confirmationRequiredTools",
				"${input:confirmationRequiredTools}",
				"--connectionString",
				"${input:connectionString}",
				"--disabledTools",
				"${input:disabledTools}",
				"--dryRun",
				"${input:dryRun}",
				"--embeddingsValidation",
				"${input:embeddingsValidation}",
				"--exportCleanupIntervalMs",
				"${input:exportCleanupIntervalMs}",
				"--exportTimeoutMs",
				"${input:exportTimeoutMs}",
				"--exportsPath",
				"${input:exportsPath}",
				"--externallyManagedSessions",
				"${input:externallyManagedSessions}",
				"--healthCheckHost",
				"${input:healthCheckHost}",
				"--healthCheckPort",
				"${input:healthCheckPort}",
				"--httpBodyLimit",
				"${input:httpBodyLimit}",
				"--httpHeaders",
				"${input:httpHeaders}",
				"--httpHost",
				"${input:httpHost}",
				"--httpPort",
				"${input:httpPort}",
				"--httpResponseType",
				"${input:httpResponseType}",
				"--idleTimeoutMs",
				"${input:idleTimeoutMs}",
				"--indexCheck",
				"${input:indexCheck}",
				"--logPath",
				"${input:logPath}",
				"--loggers",
				"${input:loggers}",
				"--maxBytesPerQuery",
				"${input:maxBytesPerQuery}",
				"--maxDocumentsPerQuery",
				"${input:maxDocumentsPerQuery}",
				"--notificationTimeoutMs",
				"${input:notificationTimeoutMs}",
				"--previewFeatures",
				"${input:previewFeatures}",
				"--readOnly",
				"${input:readOnly}",
				"--telemetry",
				"${input:telemetry}",
				"--transport",
				"${input:transport}",
				"--vectorSearchDimensions",
				"${input:vectorSearchDimensions}",
				"--vectorSearchSimilarityFunction",
				"${input:vectorSearchSimilarityFunction}",
				"--voyageApiKey",
				"${input:voyageApiKey}"
			],
			"env": {
				"MDB_MCP_ALLOW_REQUEST_OVERRIDES": "${input:MDB_MCP_ALLOW_REQUEST_OVERRIDES}",
				"MDB_MCP_API_CLIENT_ID": "${input:MDB_MCP_API_CLIENT_ID}",
				"MDB_MCP_API_CLIENT_SECRET": "${input:MDB_MCP_API_CLIENT_SECRET}",
				"MDB_MCP_ASSISTANT_BASE_URL": "${input:MDB_MCP_ASSISTANT_BASE_URL}",
				"MDB_MCP_ATLAS_TEMPORARY_DATABASE_USER_LIFETIME_MS": "${input:MDB_MCP_ATLAS_TEMPORARY_DATABASE_USER_LIFETIME_MS}",
				"MDB_MCP_CONFIRMATION_REQUIRED_TOOLS": "${input:MDB_MCP_CONFIRMATION_REQUIRED_TOOLS}",
				"MDB_MCP_CONNECTION_STRING": "${input:MDB_MCP_CONNECTION_STRING}",
				"MDB_MCP_DISABLED_TOOLS": "${input:MDB_MCP_DISABLED_TOOLS}",
				"MDB_MCP_DRY_RUN": "${input:MDB_MCP_DRY_RUN}",
				"MDB_MCP_EMBEDDINGS_VALIDATION": "${input:MDB_MCP_EMBEDDINGS_VALIDATION}",
				"MDB_MCP_EXPORT_CLEANUP_INTERVAL_MS": "${input:MDB_MCP_EXPORT_CLEANUP_INTERVAL_MS}",
				"MDB_MCP_EXPORT_TIMEOUT_MS": "${input:MDB_MCP_EXPORT_TIMEOUT_MS}",
				"MDB_MCP_EXPORTS_PATH": "${input:MDB_MCP_EXPORTS_PATH}",
				"MDB_MCP_EXTERNALLY_MANAGED_SESSIONS": "${input:MDB_MCP_EXTERNALLY_MANAGED_SESSIONS}",
				"MDB_MCP_HEALTH_CHECK_HOST": "${input:MDB_MCP_HEALTH_CHECK_HOST}",
				"MDB_MCP_HEALTH_CHECK_PORT": "${input:MDB_MCP_HEALTH_CHECK_PORT}",
				"MDB_MCP_HTTP_BODY_LIMIT": "${input:MDB_MCP_HTTP_BODY_LIMIT}",
				"MDB_MCP_HTTP_HEADERS": "${input:MDB_MCP_HTTP_HEADERS}",
				"MDB_MCP_HTTP_HOST": "${input:MDB_MCP_HTTP_HOST}",
				"MDB_MCP_HTTP_PORT": "${input:MDB_MCP_HTTP_PORT}",
				"MDB_MCP_HTTP_RESPONSE_TYPE": "${input:MDB_MCP_HTTP_RESPONSE_TYPE}",
				"MDB_MCP_IDLE_TIMEOUT_MS": "${input:MDB_MCP_IDLE_TIMEOUT_MS}",
				"MDB_MCP_INDEX_CHECK": "${input:MDB_MCP_INDEX_CHECK}",
				"MDB_MCP_LOG_PATH": "${input:MDB_MCP_LOG_PATH}",
				"MDB_MCP_LOGGERS": "${input:MDB_MCP_LOGGERS}",
				"MDB_MCP_MAX_BYTES_PER_QUERY": "${input:MDB_MCP_MAX_BYTES_PER_QUERY}",
				"MDB_MCP_MAX_DOCUMENTS_PER_QUERY": "${input:MDB_MCP_MAX_DOCUMENTS_PER_QUERY}",
				"MDB_MCP_NOTIFICATION_TIMEOUT_MS": "${input:MDB_MCP_NOTIFICATION_TIMEOUT_MS}",
				"MDB_MCP_PREVIEW_FEATURES": "${input:MDB_MCP_PREVIEW_FEATURES}",
				"MDB_MCP_READ_ONLY": "${input:MDB_MCP_READ_ONLY}",
				"MDB_MCP_TELEMETRY": "${input:MDB_MCP_TELEMETRY}",
				"MDB_MCP_TRANSPORT": "${input:MDB_MCP_TRANSPORT}",
				"MDB_MCP_VECTOR_SEARCH_DIMENSIONS": "${input:MDB_MCP_VECTOR_SEARCH_DIMENSIONS}",
				"MDB_MCP_VECTOR_SEARCH_SIMILARITY_FUNCTION": "${input:MDB_MCP_VECTOR_SEARCH_SIMILARITY_FUNCTION}",
				"MDB_MCP_VOYAGE_API_KEY": "${input:MDB_MCP_VOYAGE_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.8.0"
		},
		"com.apify/apify-mcp-server": {
			"type": "http",
			"url": "https://mcp.apify.com/",
			"headers": {
				"Authorization": "${input:Authorization}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.9.7"
		},
		"io.github.wonderwhy-er/desktop-commander": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--registry",
				"https://registry.npmjs.org",
				"@wonderwhy-er/desktop-commander@0.2.38"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.2.38"
		},
		"doist/todoist-ai": {
			"type": "http",
			"url": "https://ai.todoist.net/mcp",
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"pydantic/logfire-mcp": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"logfire-mcp@v0.6.0",
				"--read-token",
				"${input:logfire_token}",
				"--base-url",
				"${input:logfire_base_url}"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"com.sonatype/dependency-management-mcp-server": {
			"type": "http",
			"url": "https://mcp.guide.sonatype.com/mcp",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.2"
		},
		"com.glean/mcp": {
			"type": "http",
			"url": "https://{baseUrl}/mcp/{server-name}",
			"gallery": "https://api.mcp.github.com",
			"version": "1.2.0"
		},
		"dev.svelte/mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@sveltejs/mcp@0.1.20"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.1.20"
		},
		"huggingface/hf-mcp-server": {
			"type": "http",
			"url": "https://huggingface.co/mcp?login",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"azure-ai-foundry/mcp-foundry": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--prerelease=allow",
				"--from",
				"git+https://github.com/azure-ai-foundry/mcp-foundry.git",
				"run-azure-ai-foundry-mcp",
				"--envFile",
				"${input:env_file_path}"
			],
			"env": {
				"GITHUB_TOKEN": "${input:github_token}",
				"AZURE_AI_SEARCH_ENDPOINT": "${input:ai_search_endpoint}",
				"AZURE_AI_SEARCH_API_VERSION": "${input:ai_search_api_version}",
				"SEARCH_AUTHENTICATION_METHOD": "${input:search_auth_method}",
				"AZURE_TENANT_ID": "${input:azure_tenant_id}",
				"AZURE_CLIENT_ID": "${input:azure_client_id}",
				"AZURE_CLIENT_SECRET": "${input:azure_client_secret}",
				"AZURE_AI_SEARCH_API_KEY": "${input:ai_search_api_key}",
				"EVAL_DATA_DIR": "${input:eval_data_dir}",
				"AZURE_OPENAI_ENDPOINT": "${input:az_openai_endpoint}",
				"AZURE_OPENAI_API_KEY": "${input:az_openai_api_key}",
				"AZURE_OPENAI_DEPLOYMENT": "${input:az_openai_deployment}",
				"AZURE_OPENAI_API_VERSION": "${input:az_openai_api_version}",
				"AZURE_AI_PROJECT_ENDPOINT": "${input:ai_project_endpoint}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"sunriseapps/imagesorcery-mcp": {
			"type": "stdio",
			"command": "other",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"com.figma.mcp/mcp": {
			"type": "http",
			"url": "https://mcp.figma.com/mcp",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.3"
		},
		"io.github.SonarSource/sonarqube-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"SONARQUBE_TOKEN",
				"-e",
				"SONARQUBE_ORG",
				"-e",
				"SONARQUBE_URL",
				"docker.io/mcp/sonarqube:latest"
			],
			"env": {
				"SONARQUBE_TOKEN": "${input:SONARQUBE_TOKEN}",
				"SONARQUBE_ORG": "${input:SONARQUBE_ORG}",
				"SONARQUBE_URL": "${input:SONARQUBE_URL}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.10.0"
		},
		"io.github.getsentry/sentry-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@sentry/mcp-server@0.25.0"
			],
			"env": {
				"SENTRY_ACCESS_TOKEN": "${input:SENTRY_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.25.0"
		},
		"elastic/mcp-server-elasticsearch": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"run",
				"-i",
				"--rm",
				"-e",
				"$ES_URL",
				"-e",
				"$ES_API_KEY",
				"docker.elastic.co/mcp/elasticsearch",
				"stdio",
				"-e",
				"ES_URL",
				"-e",
				"ES_API_KEY",
				"docker.elastic.co/mcp/elasticsearch:latest"
			],
			"env": {
				"ES_URL": "${input:es_url}",
				"ES_API_KEY": "${input:es_api_key}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"antfu/nuxt-mcp": {
			"type": "http",
			"url": "https://mcp.nuxt.com/sse",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		}
	},
	"inputs": [
		{
			"id": "NETDATA_CLOUD_API_TOKEN",
			"type": "promptString",
			"description": "Netdata Cloud API token (create at app.netdata.cloud > User Settings > API Tokens with scope:mcp)",
			"password": true
		},
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		},
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		},
		{
			"id": "unity_mcp_server_src",
			"type": "promptString",
			"description": "Absolute path to the Unity MCP Server 'src' folder installed by the Unity package (e.g., macOS: ~/Library/Application Support/UnityMCP/UnityMcpServer/src; Windows: %USERPROFILE%/AppData/Local/UnityMCP/UnityMcpServer/src; Linux: ~/.local/share/UnityMCP/UnityMcpServer/src).",
			"password": false
		},
		{
			"id": "api_key",
			"type": "promptString",
			"description": "your API key",
			"password": true
		},
		{
			"id": "ado_org",
			"type": "promptString",
			"description": "Azure DevOps organization name (e.g., contoso).",
			"password": false
		},
		{
			"id": "ado_domain",
			"type": "promptString",
			"description": "Repeat to enable specific domains: core, work, work-items, search, test-plans, repositories, wiki, pipelines, advanced-security.",
			"password": false
		},
		{
			"id": "TAVILY_API_KEY",
			"type": "promptString",
			"description": "Your Tavily API key from tavily.com",
			"password": true
		},
		{
			"id": "DEFAULT_PARAMETERS",
			"type": "promptString",
			"description": "JSON string with default search parameters (e.g., {\"include_images\": true, \"max_results\": 15})",
			"password": false
		},
		{
			"id": "e",
			"type": "promptString",
			"description": "Set an environment variable in the runtime",
			"password": false
		},
		{
			"id": "e",
			"type": "promptString",
			"description": "Set an environment variable in the runtime",
			"password": false
		},
		{
			"id": "e",
			"type": "promptString",
			"description": "Set an environment variable in the runtime",
			"password": false
		},
		{
			"id": "TFE_ADDRESS",
			"type": "promptString",
			"description": "HCP Terraform or Terraform Enterprise base URL.",
			"password": false,
			"default": "https://app.terraform.io"
		},
		{
			"id": "TFE_TOKEN",
			"type": "promptString",
			"description": "HCP Terraform or Terraform Enterprise API token used to authenticate requests.",
			"password": true
		},
		{
			"id": "ENABLE_TF_OPERATIONS",
			"type": "pickString",
			"description": "Set to true to enable tools that execute Terraform operations requiring explicit approval.",
			"password": false,
			"default": "false",
			"options": [
				"true",
				"false"
			]
		},
		{
			"id": "MDB_MCP_ALLOW_REQUEST_OVERRIDES",
			"type": "promptString",
			"description": "When set to true, allows configuration values to be overridden via request headers and query parameters.",
			"password": false
		},
		{
			"id": "MDB_MCP_API_CLIENT_ID",
			"type": "promptString",
			"description": "Atlas API client ID for authentication. Required for running Atlas tools.",
			"password": true
		},
		{
			"id": "MDB_MCP_API_CLIENT_SECRET",
			"type": "promptString",
			"description": "Atlas API client secret for authentication. Required for running Atlas tools.",
			"password": true
		},
		{
			"id": "MDB_MCP_ASSISTANT_BASE_URL",
			"type": "promptString",
			"description": "Base URL for the MongoDB Assistant API.",
			"password": false
		},
		{
			"id": "MDB_MCP_ATLAS_TEMPORARY_DATABASE_USER_LIFETIME_MS",
			"type": "promptString",
			"description": "Time in milliseconds that temporary database users created when connecting to MongoDB Atlas clusters will remain active before being automatically deleted.",
			"password": false
		},
		{
			"id": "MDB_MCP_CONFIRMATION_REQUIRED_TOOLS",
			"type": "promptString",
			"description": "Comma separated values of tool names that require user confirmation before execution. Requires the client to support elicitation.",
			"password": false
		},
		{
			"id": "MDB_MCP_CONNECTION_STRING",
			"type": "promptString",
			"description": "MongoDB connection string for direct database connections. Optional, if not set, you'll need to call the connect tool before interacting with MongoDB data.",
			"password": true
		},
		{
			"id": "MDB_MCP_DISABLED_TOOLS",
			"type": "promptString",
			"description": "Comma separated values of tool names, operation types, and/or categories of tools that will be disabled.",
			"password": false
		},
		{
			"id": "MDB_MCP_DRY_RUN",
			"type": "promptString",
			"description": "When true, runs the server in dry mode: dumps configuration and enabled tools, then exits without starting the server.",
			"password": false
		},
		{
			"id": "MDB_MCP_EMBEDDINGS_VALIDATION",
			"type": "promptString",
			"description": "When set to false, disables validation of embeddings dimensions.",
			"password": false
